<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="CucumberUIFramework - Smoke Suite"
       parallel="none"
       verbose="2">

    <listeners>
        <listener class-name="com.automation.listeners.TestNGListener"/>
    </listeners>

    <test name="Smoke Tests">
        <classes>
            <class name="com.automation.runners.SmokeTestRunner"/>
        </classes>
    </test>

</suite>
